#!/bin/bash
set -e

WAKEALARM_FILE="/sys/class/rtc/rtc0/wakealarm"
DELAY=0
INPUT_TIME=""

usage() {
    cat <<EOF
Usage: $0 [--delay SECONDS] <time>

Set the RTC wake alarm and then enter hybrid-sleep.

Supported time formats:
  +90                    → 90 seconds from now
  +3600                  → 1 hour from now
  1712345678             → absolute Unix epoch timestamp
  08:30                  → today at 08:30 (if already passed, tomorrow)
  2026-12-25 07:30:00    → exact date & time
  "now + 1 hour"         → any string accepted by 'date -d'

Options:
  --delay N              → wait N seconds before hybrid-sleep (e.g., for logout)
EOF
    exit 1
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --delay)
            DELAY="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        *)
            INPUT_TIME="$1"
            shift
            ;;
    esac
done

[ -z "$INPUT_TIME" ] && usage

# Check for root / sudo
if [ "$EUID" -ne 0 ]; then
    echo "This script must be run as root (or with sudo)."
    exit 1
fi

# Check if wakealarm file exists
if [ ! -f "$WAKEALARM_FILE" ]; then
    echo "Error: $WAKEALARM_FILE not found. RTC wakealarm not supported?"
    exit 1
fi

now=$(date +%s)

# Determine target epoch from input
if [[ "$INPUT_TIME" =~ ^\+([0-9]+)$ ]]; then
    # Relative time: +<seconds>
    diff="${BASH_REMATCH[1]}"
    wake_epoch=$(( now + diff ))
elif [[ "$INPUT_TIME" =~ ^[0-9]+$ ]]; then
    # Absolute epoch timestamp
    wake_epoch="$INPUT_TIME"
else
    # Anything else: try 'date -d'
    if ! wake_epoch=$(date -d "$INPUT_TIME" +%s 2>/dev/null); then
        echo "Error: Cannot parse time string '$INPUT_TIME'."
        exit 1
    fi

    # If only a time of day was given (no date) and the time is in the past,
    # push it to tomorrow.
    if ! [[ "$INPUT_TIME" =~ [0-9]{4}-[0-9]{2}-[0-9]{2} ]] && [ "$wake_epoch" -le "$now" ]; then
        wake_epoch=$(( wake_epoch + 86400 ))
        echo "Specified time appears to be in the past; moved to tomorrow: $(date -d @"$wake_epoch")"
    fi
fi

# Verify wake time is in the future
if [ "$wake_epoch" -le "$now" ]; then
    echo "Error: Wake time is in the past ($(date -d @"$wake_epoch"))."
    exit 1
fi

# Write the wakealarm (absolute epoch)
echo "$wake_epoch" > "$WAKEALARM_FILE"
if [ $? -eq 0 ]; then
    echo "RTC wake alarm set to $(date -d @"$wake_epoch") (epoch $wake_epoch)"
else
    echo "Failed to write to $WAKEALARM_FILE"
    exit 1
fi

# Optional delay for logout
if [ "$DELAY" -gt 0 ]; then
    echo "Waiting $DELAY seconds before hybrid-sleep..."
    sleep "$DELAY"
fi

# Go to hybrid-sleep
echo "Entering hybrid-sleep..."
systemctl hybrid-sleep